# Public base URL — used to render copy-paste short links in the UI
PUBLIC_BASE_URL=http://localhost:3000

# Host port the app is exposed on
APP_PORT=3000

# JWT signing secret — REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Postgres
POSTGRES_USER=snip
POSTGRES_PASSWORD=snip
POSTGRES_DB=snip

# Custom domain (only used with docker-compose.caddy.yml override)
# Set DOMAIN to your hostname and ACME_EMAIL for Let's Encrypt notifications.
# Also set PUBLIC_BASE_URL=https://your-domain above.
DOMAIN=links.example.com
ACME_EMAIL=you@example.com
